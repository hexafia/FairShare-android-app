<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    app:cardCornerRadius="14dp"
    app:cardElevation="2dp"
    app:cardBackgroundColor="@color/bg_card"
    android:layout_marginBottom="10dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:padding="16dp">

        <!-- Debtor initial -->
        <FrameLayout
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:background="@drawable/ic_launcher_background"
            android:backgroundTint="#FFEBEE">

            <TextView
                android:id="@+id/tvDebtorInitial"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:gravity="center"
                android:textColor="@color/expense_red"
                android:textSize="16sp"
                android:textStyle="bold"
                tools:text="B" />

        </FrameLayout>

        <!-- Arrow + Info -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:paddingStart="12dp"
            android:paddingEnd="12dp">

            <TextView
                android:id="@+id/tvSettlementDescription"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="@color/text_primary"
                android:textSize="14sp"
                android:textStyle="bold"
                tools:text="Brent → Anna" />

            <TextView
                android:id="@+id/tvExpenseTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="@color/text_secondary"
                android:textSize="12sp"
                android:layout_marginTop="2dp"
                android:visibility="gone"
                tools:text="for: Dinner" />

            <TextView
                android:id="@+id/tvSettlementAmount"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="@color/expense_red"
                android:textSize="16sp"
                android:textStyle="bold"
                android:layout_marginTop="2dp"
                tools:text="₱500.00" />

        </LinearLayout>

        <!-- Creditor initial -->
        <FrameLayout
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:background="@drawable/ic_launcher_background"
            android:backgroundTint="#E8F5E9">

            <TextView
                android:id="@+id/tvCreditorInitial"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:gravity="center"
                android:textColor="@color/income_green"
                android:textSize="16sp"
                android:textStyle="bold"
                tools:text="A" />

        </FrameLayout>

        <!-- Settle button -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnSettle"
            android:layout_width="wrap_content"
            android:layout_height="36dp"
            android:text="Settle"
            android:textAllCaps="false"
            android:textSize="12sp"
            android:layout_marginStart="8dp"
            android:minWidth="0dp"
            android:paddingStart="12dp"
            android:paddingEnd="12dp"
            app:backgroundTint="#38BDB0"
            app:cornerRadius="18dp" />

        <!-- Settled label (shown when already settled) -->
        <TextView
            android:id="@+id/tvSettledLabel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="✓ Settled"
            android:textColor="@color/income_green"
            android:textSize="12sp"
            android:textStyle="bold"
            android:layout_marginStart="8dp"
            android:visibility="gone" />

    </LinearLayout>

</com.google.android.material.card.MaterialCardView>
