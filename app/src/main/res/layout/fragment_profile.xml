<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/off_white">

    <View
        android:id="@+id/headerBackground"
        android:layout_width="match_parent"
        android:layout_height="220dp"
        android:background="@color/teal"
        app:layout_constraintTop_toTopOf="parent" />

    <TextView
        android:id="@+id/tvHeaderTitle"
        style="@style/TextAppearance.MyApp.Heading1"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="24dp"
        android:layout_marginTop="48dp"
        android:text="@string/profile_title"
        android:textColor="@color/white"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <TextView
        android:id="@+id/tvHeaderSubtitle"
        style="@style/TextAppearance.MyApp.BodyNormal"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="24dp"
        android:text="@string/profile_subtitle"
        android:textColor="@color/white"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/tvHeaderTitle" />

    
    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginTop="24dp"
        android:background="@drawable/bg_dashboard_content"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintTop_toBottomOf="@id/tvHeaderSubtitle">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="24dp">

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="24dp"
                app:cardElevation="0dp"
                app:strokeWidth="0dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center"
                    android:orientation="vertical"
                    android:padding="24dp">

                    <!-- Profile info - Now the focal point -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:gravity="center">

                        <TextView
                            android:id="@+id/tvDisplayName"
                            style="@style/TextAppearance.MyApp.Heading1"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:textColor="@color/text_primary"
                            android:textSize="32sp"
                            android:textStyle="bold"
                            android:layout_marginBottom="8dp"
                            tools:text="User Name" />

                        <TextView
                            android:id="@+id/tvTagline"
                            style="@style/TextAppearance.MyApp.BodyNormal"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:textColor="@color/gray"
                            android:textStyle="italic"
                            android:textSize="16sp"
                            android:layout_marginBottom="24dp"
                            tools:text="#0000" />
                    </LinearLayout>

                    <!-- Contact information with icons -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:layout_marginBottom="24dp">

                        <!-- Email -->
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical"
                            android:layout_marginBottom="16dp">
                            
                            <ImageView
                                android:layout_width="20dp"
                                android:layout_height="20dp"
                                android:src="@android:drawable/ic_dialog_email"
                                android:tint="@color/teal"
                                android:layout_marginEnd="12dp" />
                            
                            <LinearLayout
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:orientation="vertical">
                                <TextView 
                                    style="@style/TextAppearance.MyApp.BodySmall" 
                                    android:text="@string/label_email" 
                                    android:textColor="@color/gray" 
                                    android:layout_width="wrap_content" 
                                    android:layout_height="wrap_content" />
                                <TextView 
                                    android:id="@+id/tvUserEmail" 
                                    style="@style/TextAppearance.MyApp.BodyNormal" 
                                    android:text="@string/default_user_email" 
                                    android:layout_width="wrap_content" 
                                    android:layout_height="wrap_content" />
                            </LinearLayout>
                        </LinearLayout>

                        <!-- Phone -->
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical"
                            android:layout_marginBottom="16dp">
                            
                            <ImageView
                                android:layout_width="20dp"
                                android:layout_height="20dp"
                                android:src="@android:drawable/ic_menu_call"
                                android:tint="@color/teal"
                                android:layout_marginEnd="12dp" />
                            
                            <LinearLayout
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:orientation="vertical">
                                <TextView 
                                    style="@style/TextAppearance.MyApp.BodySmall" 
                                    android:text="@string/label_phone" 
                                    android:textColor="@color/gray" 
                                    android:layout_width="wrap_content" 
                                    android:layout_height="wrap_content" />
                                <TextView 
                                    android:id="@+id/tvUserPhone" 
                                    style="@style/TextAppearance.MyApp.BodyNormal" 
                                    android:text="@string/default_user_phone" 
                                    android:layout_width="wrap_content" 
                                    android:layout_height="wrap_content" />
                            </LinearLayout>
                        </LinearLayout>

                        <!-- Location -->
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical">
                            
                            <ImageView
                                android:layout_width="20dp"
                                android:layout_height="20dp"
                                android:src="@android:drawable/ic_menu_mylocation"
                                android:tint="@color/teal"
                                android:layout_marginEnd="12dp" />
                            
                            <LinearLayout
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:orientation="vertical">
                                <TextView 
                                    style="@style/TextAppearance.MyApp.BodySmall" 
                                    android:text="@string/label_location" 
                                    android:textColor="@color/gray" 
                                    android:layout_width="wrap_content" 
                                    android:layout_height="wrap_content" />
                                <TextView 
                                    android:id="@+id/tvUserLocation" 
                                    style="@style/TextAppearance.MyApp.BodyNormal" 
                                    android:text="@string/default_user_location" 
                                    android:layout_width="wrap_content" 
                                    android:layout_height="wrap_content" />
                            </LinearLayout>
                        </LinearLayout>
                    </LinearLayout>

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnEditProfile"
                        android:layout_width="match_parent"
                        android:layout_height="56dp"
                        android:text="@string/edit_profile"
                        android:textAllCaps="false"
                        app:backgroundTint="@color/teal"
                        app:cornerRadius="12dp"
                        app:icon="@drawable/ic_edit"
                        app:iconGravity="textStart" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnLogout"
                style="@style/Widget.MaterialComponents.Button.TextButton"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginTop="24dp"
                android:text="Log Out"
                android:textColor="@color/orange"
                app:icon="@drawable/ic_logout"
                app:iconTint="@color/orange" />

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>
