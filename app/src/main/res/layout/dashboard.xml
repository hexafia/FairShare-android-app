<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/off_white">

    <!-- Teal Header -->
    <View
        android:id="@+id/headerBackground"
        android:layout_width="match_parent"
        android:layout_height="220dp"
        android:background="@color/teal"
        app:layout_constraintTop_toTopOf="parent" />

    <TextView
        android:id="@+id/tvHeaderTitle"
        style="@style/TextAppearance.MyApp.Heading1"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="24dp"
        android:layout_marginTop="48dp"
        android:text="Dashboard"
        android:textColor="@color/white"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <TextView
        android:id="@+id/tvHeaderSubtitle"
        style="@style/TextAppearance.MyApp.BodyNormal"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="24dp"
        android:text="Welcome back, User!"
        android:textColor="@color/white"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/tvHeaderTitle" />

    <!-- Main Content Area with Rounded Corners -->
    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginTop="24dp"
        android:background="@drawable/bg_dashboard_content"
        app:layout_constraintBottom_toTopOf="@id/bottom_nav_container"
        app:layout_constraintTop_toBottomOf="@id/tvHeaderSubtitle">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="24dp">

            <!-- Monthly Total Expense Card -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardCornerRadius="24dp"
                app:cardElevation="0dp"
                app:strokeWidth="0dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="24dp">

                    <TextView
                        style="@style/TextAppearance.MyApp.BodyNormal"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Monthly Total Expense"
                        android:textColor="@color/gray" />

                    <TextView
                        android:id="@+id/tvTotalAmount"
                        style="@style/TextAppearance.MyApp.Heading1"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:text="Php 9,023.42"
                        android:textColor="@color/off_black"
                        android:textSize="32sp" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="16dp"
                        android:orientation="horizontal">

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical">
                            <TextView
                                style="@style/TextAppearance.MyApp.BodySmall"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="By personal"
                                android:textColor="@color/gray" />
                            <TextView
                                style="@style/TextAppearance.MyApp.BodyNormal"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Php 1,209.23"
                                android:textStyle="bold" />
                        </LinearLayout>

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical">
                            <TextView
                                style="@style/TextAppearance.MyApp.BodySmall"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="By group"
                                android:textColor="@color/gray" />
                            <TextView
                                style="@style/TextAppearance.MyApp.BodyNormal"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Php 7,814.19"
                                android:textStyle="bold" />
                        </LinearLayout>
                    </LinearLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Action Buttons -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:orientation="horizontal">

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnAddExpense"
                    android:layout_width="0dp"
                    android:layout_height="56dp"
                    android:layout_weight="1"
                    android:layout_marginEnd="8dp"
                    android:text="Add Expense"
                    android:textAllCaps="false"
                    app:backgroundTint="@color/teal"
                    app:cornerRadius="12dp" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnNewGroup"
                    android:layout_width="0dp"
                    android:layout_height="56dp"
                    android:layout_weight="1"
                    android:layout_marginStart="8dp"
                    android:text="New Group"
                    android:textAllCaps="false"
                    app:backgroundTint="@color/orange"
                    app:cornerRadius="12dp" />
            </LinearLayout>

            <!-- Recent Expenses -->
            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp">
                <TextView
                    style="@style/TextAppearance.MyApp.Heading3"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Recent Expenses" />
                <TextView
                    style="@style/TextAppearance.MyApp.BodySmaller"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_alignParentEnd="true"
                    android:text="View all"
                    android:textColor="@color/teal"
                    android:layout_centerVertical="true"
                    android:textStyle="bold" />
            </RelativeLayout>

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                app:cardCornerRadius="16dp"
                app:cardElevation="2dp"
                app:strokeColor="@color/light_orange"
                app:strokeWidth="1dp">
                <androidx.constraintlayout.widget.ConstraintLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:padding="16dp">
                    <TextView
                        android:id="@+id/tvExpTitle"
                        style="@style/TextAppearance.MyApp.BodyNormal"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Expense"
                        android:textStyle="bold"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toTopOf="parent" />
                    <TextView
                        style="@style/TextAppearance.MyApp.BodySmaller"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Personal"
                        android:textColor="@color/gray"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toBottomOf="@id/tvExpTitle" />
                    <TextView
                        style="@style/TextAppearance.MyApp.BodyNormal"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Php 150.75"
                        app:layout_constraintBottom_toBottomOf="parent"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintTop_toTopOf="parent" />
                </androidx.constraintlayout.widget.ConstraintLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Active Groups -->
            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp">
                <TextView
                    style="@style/TextAppearance.MyApp.Heading3"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Active Groups" />
                <TextView
                    style="@style/TextAppearance.MyApp.BodySmaller"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_alignParentEnd="true"
                    android:text="View all"
                    android:textColor="@color/teal"
                    android:layout_centerVertical="true"
                    android:textStyle="bold" />
            </RelativeLayout>

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                app:cardCornerRadius="16dp"
                app:cardElevation="2dp"
                app:strokeColor="@color/light_orange"
                app:strokeWidth="1dp">
                <androidx.constraintlayout.widget.ConstraintLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:padding="16dp">
                    <ImageView
                        android:id="@+id/ivGrpIcon"
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:src="@drawable/ic_group"
                        app:tint="@color/teal"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toTopOf="parent"
                        app:layout_constraintBottom_toBottomOf="parent" />
                    <TextView
                        android:id="@+id/tvGrpName"
                        style="@style/TextAppearance.MyApp.BodyNormal"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="12dp"
                        android:text="Team"
                        android:textStyle="bold"
                        app:layout_constraintStart_toEndOf="@id/ivGrpIcon"
                        app:layout_constraintTop_toTopOf="parent" />
                    <TextView
                        style="@style/TextAppearance.MyApp.BodySmaller"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="4 members"
                        android:textColor="@color/gray"
                        app:layout_constraintStart_toStartOf="@id/tvGrpName"
                        app:layout_constraintTop_toBottomOf="@id/tvGrpName" />
                    <TextView
                        style="@style/TextAppearance.MyApp.BodyNormal"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Php 1,299.00"
                        app:layout_constraintBottom_toBottomOf="parent"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintTop_toTopOf="parent" />
                </androidx.constraintlayout.widget.ConstraintLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Pending IOUs -->
            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp">
                <TextView
                    style="@style/TextAppearance.MyApp.Heading3"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Pending IOUs" />
                <TextView
                    style="@style/TextAppearance.MyApp.BodySmaller"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_alignParentEnd="true"
                    android:text="View all"
                    android:textColor="@color/teal"
                    android:layout_centerVertical="true"
                    android:textStyle="bold" />
            </RelativeLayout>

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:layout_marginBottom="16dp"
                app:cardCornerRadius="16dp"
                app:cardElevation="2dp"
                app:strokeColor="@color/light_orange"
                app:strokeWidth="1dp">
                <androidx.constraintlayout.widget.ConstraintLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:padding="16dp">
                    <ImageView
                        android:id="@+id/ivIouIcon"
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:src="@drawable/ic_personal"
                        app:tint="@color/orange"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toTopOf="parent"
                        app:layout_constraintBottom_toBottomOf="parent" />
                    <TextView
                        android:id="@+id/tvIouName"
                        style="@style/TextAppearance.MyApp.BodyNormal"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="12dp"
                        android:text="Jane Doe"
                        android:textStyle="bold"
                        app:layout_constraintStart_toEndOf="@id/ivIouIcon"
                        app:layout_constraintTop_toTopOf="parent" />
                    <TextView
                        style="@style/TextAppearance.MyApp.BodySmaller"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Php 349.75"
                        android:textColor="@color/gray"
                        app:layout_constraintStart_toStartOf="@id/tvIouName"
                        app:layout_constraintTop_toBottomOf="@id/tvIouName" />
                    <com.google.android.material.button.MaterialButton
                        android:layout_width="wrap_content"
                        android:layout_height="36dp"
                        android:text="Nudge"
                        android:textSize="10sp"
                        android:padding="0dp"
                        android:textAllCaps="false"
                        app:backgroundTint="@color/orange"
                        app:cornerRadius="12dp"
                        app:layout_constraintBottom_toBottomOf="parent"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintTop_toTopOf="parent" />
                </androidx.constraintlayout.widget.ConstraintLayout>
            </com.google.android.material.card.MaterialCardView>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

    <!-- Bottom Nav -->
    <FrameLayout
        android:id="@+id/bottom_nav_container"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:layout_constraintBottom_toBottomOf="parent">
        <include layout="@layout/layout_bottom_navigation" />
    </FrameLayout>

</androidx.constraintlayout.widget.ConstraintLayout>