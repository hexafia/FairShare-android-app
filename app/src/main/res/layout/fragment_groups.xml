<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/off_white"
    tools:context=".ui.groups.GroupsFragment">

    <!-- Teal Header -->
    <View
        android:id="@+id/headerBackground"
        android:layout_width="match_parent"
        android:layout_height="220dp"
        android:background="@color/teal" />

    <TextView
        android:id="@+id/tvHeaderTitle"
        style="@style/TextAppearance.MyApp.Heading1"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="24dp"
        android:layout_marginTop="48dp"
        android:text="Group"
        android:textColor="@color/white" />

    <TextView
        android:id="@+id/tvHeaderSubtitle"
        style="@style/TextAppearance.MyApp.BodyNormal"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="24dp"
        android:layout_marginTop="80dp"
        android:text="Manage shared expenses"
        android:textColor="@color/white" />

    <!-- Main Content Area with Rounded Corners -->
    <androidx.core.widget.NestedScrollView
        android:id="@+id/nestedScrollView"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_marginTop="120dp"
        android:background="@drawable/bg_dashboard_content"
        android:clipToPadding="false"
        android:paddingBottom="88dp"
        app:layout_behavior="@string/appbar_scrolling_view_behavior">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="24dp">

            <!-- Quick Actions Buttons -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="24dp"
                android:orientation="horizontal">

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnCreateNewGroup"
                    android:layout_width="0dp"
                    android:layout_height="64dp"
                    android:layout_weight="1"
                    android:layout_marginEnd="8dp"
                    android:text="New Group"
                    android:textAllCaps="false"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    app:backgroundTint="@color/teal"
                    app:cornerRadius="16dp" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnJoinViaCode"
                    android:layout_width="0dp"
                    android:layout_height="64dp"
                    android:layout_weight="1"
                    android:layout_marginStart="8dp"
                    android:text="Join via Code"
                    android:textAllCaps="false"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    app:backgroundTint="@color/orange"
                    app:cornerRadius="16dp" />
            </LinearLayout>

            <!-- Active Groups Section -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginBottom="24dp">

                <TextView
                    style="@style/TextAppearance.MyApp.Heading3"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="16dp"
                    android:text="Active Groups"
                    android:textColor="@color/teal" />

                <!-- Empty state for active groups -->
                <LinearLayout
                    android:id="@+id/layoutEmptyActive"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center"
                    android:orientation="vertical"
                    android:paddingTop="24dp"
                    android:paddingBottom="24dp"
                    android:visibility="gone">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="No active groups"
                        android:textColor="@color/gray"
                        android:textSize="16sp"
                        android:gravity="center" />

                </LinearLayout>

                <!-- Active groups list -->
                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/rvActiveGroups"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:nestedScrollingEnabled="false"
                    android:clipToPadding="false"
                    tools:listitem="@layout/item_group" />

            </LinearLayout>

            <!-- Settled Groups Section -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="16dp">

                    <TextView
                        style="@style/TextAppearance.MyApp.Heading3"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Settled Groups"
                        android:textColor="@color/off_black" />

                    <ImageButton
                        android:id="@+id/btnSettledGroupsMenu"
                        android:layout_width="32dp"
                        android:layout_height="32dp"
                        android:background="?attr/selectableItemBackgroundBorderless"
                        android:src="@drawable/ic_more_vert"
                        android:contentDescription="Settled groups options"
                        android:tint="@color/primary_dark" />

                </LinearLayout>

                <!-- Empty state for settled groups -->
                <LinearLayout
                    android:id="@+id/layoutEmptySettled"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center"
                    android:orientation="vertical"
                    android:paddingTop="24dp"
                    android:paddingBottom="24dp"
                    android:visibility="gone">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="No settled groups"
                        android:textColor="@color/gray"
                        android:textSize="16sp"
                        android:gravity="center" />

                </LinearLayout>

                <!-- Settled groups list -->
                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/rvSettledGroups"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:nestedScrollingEnabled="false"
                    android:clipToPadding="false"
                    tools:listitem="@layout/item_group" />

            </LinearLayout>

        </LinearLayout>

    </androidx.core.widget.NestedScrollView>

    <!-- FloatingActionButton for creating new groups -->
    <com.google.android.material.floatingactionbutton.FloatingActionButton
        android:id="@+id/fabGlobalAction"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_margin="16dp"
        android:contentDescription="Create New Group"
        android:src="@drawable/ic_add"
        app:backgroundTint="@color/teal"
        app:tint="@color/white"
        app:fabSize="normal"
        app:layout_anchor="@id/nestedScrollView"
        app:layout_anchorGravity="bottom|end" />

</androidx.coordinatorlayout.widget.CoordinatorLayout>
