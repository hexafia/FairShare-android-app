<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:padding="16dp">

    <!-- Profile Icon -->
    <View
        android:id="@+id/profileIconBg"
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:background="@drawable/bg_group_icon"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <ImageView
        android:id="@+id/ivProfileIcon"
        android:layout_width="24dp"
        android:layout_height="24dp"
        android:src="@drawable/ic_profile"
        app:layout_constraintBottom_toBottomOf="@id/profileIconBg"
        app:layout_constraintEnd_toEndOf="@id/profileIconBg"
        app:layout_constraintStart_toStartOf="@id/profileIconBg"
        app:layout_constraintTop_toTopOf="@id/profileIconBg"
        app:tint="@color/teal" />

    <TextView
        android:id="@+id/tvPayerName"
        style="@style/TextAppearance.MyApp.Heading3"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="12dp"
        android:text="Matt"
        app:layout_constraintStart_toEndOf="@id/profileIconBg"
        app:layout_constraintTop_toTopOf="@id/profileIconBg" />

    <TextView
        android:id="@+id/tvCategory"
        style="@style/TextAppearance.MyApp.BodySmaller"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Bachelor Party"
        android:textColor="@color/gray"
        app:layout_constraintStart_toStartOf="@id/tvPayerName"
        app:layout_constraintTop_toBottomOf="@id/tvPayerName" />

    <TextView
        android:id="@+id/tvTime"
        style="@style/TextAppearance.MyApp.BodySmaller"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Time: 1 hour ago"
        android:textColor="@color/gray"
        app:layout_constraintStart_toStartOf="@id/tvPayerName"
        app:layout_constraintTop_toBottomOf="@id/tvCategory" />

    <TextView
        android:id="@+id/tvTotalAmount"
        style="@style/TextAppearance.MyApp.Heading3"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="₱1,800"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="@id/tvPayerName" />

    <TextView
        android:id="@+id/tvOweLabel"
        style="@style/TextAppearance.MyApp.BodySmaller"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="you owe: "
        android:textColor="@color/gray"
        app:layout_constraintEnd_toStartOf="@id/tvOweAmount"
        app:layout_constraintTop_toBottomOf="@id/tvTotalAmount" />

    <TextView
        android:id="@+id/tvOweAmount"
        style="@style/TextAppearance.MyApp.BodySmaller"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="₱450"
        android:textStyle="bold"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toBottomOf="@id/tvTotalAmount" />

</androidx.constraintlayout.widget.ConstraintLayout>