<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:padding="16dp">

    <!-- Group Icon Background -->
    <View
        android:id="@+id/groupIconBg"
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:background="@drawable/bg_group_icon"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <ImageView
        android:id="@+id/ivGroupIcon"
        android:layout_width="24dp"
        android:layout_height="24dp"
        app:tint="@color/teal"
        android:src="@drawable/ic_group"
        app:layout_constraintBottom_toBottomOf="@id/groupIconBg"
        app:layout_constraintEnd_toEndOf="@id/groupIconBg"
        app:layout_constraintStart_toStartOf="@id/groupIconBg"
        app:layout_constraintTop_toTopOf="@id/groupIconBg" />

    <TextView
        android:id="@+id/tvGroupName"
        style="@style/TextAppearance.MyApp.Heading3"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="12dp"
        android:text="Team"
        app:layout_constraintStart_toEndOf="@id/groupIconBg"
        app:layout_constraintTop_toTopOf="@id/groupIconBg" />

    <TextView
        android:id="@+id/tvMemberCount"
        style="@style/TextAppearance.MyApp.BodySmaller"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="4 members"
        android:textColor="@color/gray"
        app:layout_constraintStart_toStartOf="@id/tvGroupName"
        app:layout_constraintTop_toBottomOf="@id/tvGroupName" />

    <TextView
        android:id="@+id/tvCreatedDate"
        style="@style/TextAppearance.MyApp.BodySmaller"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="8dp"
        android:text="Created 03/17/2026"
        android:textColor="@color/gray"
        app:layout_constraintStart_toEndOf="@id/tvMemberCount"
        app:layout_constraintTop_toTopOf="@id/tvMemberCount" />

    <ImageView
        android:layout_width="24dp"
        android:layout_height="24dp"
        android:src="@drawable/ic_chevron_right"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:tint="@color/off_black" />

    <View
        android:id="@+id/divider"
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:layout_marginTop="12dp"
        android:background="#E0E0E0"
        app:layout_constraintTop_toBottomOf="@id/groupIconBg" />

    <TextView
        android:id="@+id/tvTotalLabel"
        style="@style/TextAppearance.MyApp.BodyNormal"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:text="Total"
        android:textColor="@color/gray"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/divider" />

    <TextView
        android:id="@+id/tvTotalValue"
        style="@style/TextAppearance.MyApp.BodyNormal"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Php 1,200.80"
        android:textStyle="bold"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/tvTotalLabel" />

    <TextView
        android:id="@+id/tvYourShareLabel"
        style="@style/TextAppearance.MyApp.BodyNormal"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Your Share"
        android:textColor="@color/orange"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="@id/tvTotalLabel" />

    <TextView
        android:id="@+id/tvYourShareValue"
        style="@style/TextAppearance.MyApp.BodyNormal"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Php 279.30"
        android:textColor="@color/orange"
        android:textStyle="bold"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toBottomOf="@id/tvYourShareLabel" />

</androidx.constraintlayout.widget.ConstraintLayout>